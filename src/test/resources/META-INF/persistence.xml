<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence
                                  http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd"
             version="2.2">

    <!--
        Test-only persistence unit backed by H2 in-memory, entirely
        separate from "kimwanyiSaccoPU" (Section 3), which looks up a
        JNDI DataSource only available inside a running Tomcat. Tests
        run standalone via `mvn test`, with no servlet container and no
        real MySQL instance — H2 lets the full JPA/Hibernate/entity layer
        be exercised without either.

        hbm2ddl=create-drop is used HERE ONLY, unlike production's
        "validate" (Section 3) — schema.sql is not applied against H2, so
        Hibernate generates the schema from the entity mappings fresh for
        every test run. This is a deliberate, acceptable divergence for a
        disposable in-memory test database; it must never be the strategy
        used against the real MySQL schema.
    -->
    <persistence-unit name="kimwanyiSaccoTestPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>com.pahappa.sacco.entity.User</class>
        <class>com.pahappa.sacco.entity.Member</class>
        <class>com.pahappa.sacco.entity.Account</class>
        <class>com.pahappa.sacco.entity.Transaction</class>
        <class>com.pahappa.sacco.entity.Loan</class>
        <class>com.pahappa.sacco.entity.LoanRepayment</class>
        <class>com.pahappa.sacco.entity.AuditLog</class>

        <properties>
            <property name="javax.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="javax.persistence.jdbc.url"
                       value="jdbc:h2:mem:kimwanyi_test;DB_CLOSE_DELAY=-1;LOCK_TIMEOUT=10000"/>
            <property name="javax.persistence.jdbc.user" value="sa"/>
            <property name="javax.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="create-drop"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

</persistence>
