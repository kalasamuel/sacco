<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                              http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Kimwanyi SACCO Management System</display-name>

    <!-- ==================== JSF FacesServlet ==================== -->
    <servlet>
        <servlet-name>Faces Servlet</servlet-name>
        <servlet-class>javax.faces.webapp.FacesServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>Faces Servlet</servlet-name>
        <url-pattern>*.xhtml</url-pattern>
    </servlet-mapping>

    <!-- Only .xhtml pages are ever served through Faces Servlet — raw .xhtml
         source under WEB-INF is not directly reachable, closing off a common
         JSF misconfiguration where view source can be downloaded by URL. -->
    <context-param>
        <param-name>javax.faces.FACELETS_SKIP_COMMENTS</param-name>
        <param-value>true</param-value>
    </context-param>
    <context-param>
        <param-name>javax.faces.PROJECT_STAGE</param-name>
        <param-value>Production</param-value>
    </context-param>
    <context-param>
        <param-name>javax.faces.STATE_SAVING_METHOD</param-name>
        <param-value>server</param-value>
        <!-- Server-side state saving: view state token references server memory,
             not a client-side blob a user could tamper with — chosen for
             integrity over the marginal memory cost, given SACCO's low
             concurrent-user count. -->
    </context-param>
    <context-param>
        <param-name>javax.faces.ENABLE_CDI_RESOLVER_CHAIN</param-name>
        <param-value>true</param-value>
    </context-param>

    <!-- ==================== RBAC / Auth enforcement filter (Section 5) ==================== -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.pahappa.sacco.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/app/*</url-pattern>
    </filter-mapping>

    <!-- ==================== CSRF protection filter (Section 5) ==================== -->
    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>com.pahappa.sacco.filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>*.xhtml</url-pattern>
    </filter-mapping>

    <!-- ==================== Security headers filter (Section 5) ==================== -->
    <filter>
        <filter-name>SecurityHeadersFilter</filter-name>
        <filter-class>com.pahappa.sacco.filter.SecurityHeadersFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeadersFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <session-config>
        <session-timeout>15</session-timeout>
        <!-- 15 minutes: a teller counter is a shared physical terminal —
             short timeout limits the window an unlocked session is exposed. -->
        <cookie-config>
            <http-only>true</http-only>
            <secure>true</secure>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <welcome-file-list>
        <welcome-file>index.xhtml</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>403</error-code>
        <location>/error/403.xhtml</location>
    </error-page>
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.xhtml</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.xhtml</location>
    </error-page>

</web-app>
